{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://small-vlm-sop-check.local/schemas/benchmark/v1/run.schema.json",
  "title": "Immutable prediction run",
  "type": "object",
  "required": ["schema_version", "run_id", "kind", "status", "immutable", "model", "dataset", "target_units"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "run_id": {"type": "string"},
    "kind": {"enum": ["prediction", "evaluation"]},
    "status": {"enum": ["complete", "failed"]},
    "immutable": {"const": true},
    "model": {"type": "object", "required": ["name", "role"]},
    "dataset": {"type": "object", "required": ["id", "split"]},
    "target_units": {"type": "array", "items": {"type": "string"}, "minItems": 1}
  },
  "additionalProperties": true
}
