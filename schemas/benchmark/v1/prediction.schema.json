{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://small-vlm-sop-check.local/schemas/benchmark/v1/prediction.schema.json",
  "title": "Frame-level model prediction",
  "type": "object",
  "required": ["schema_version", "run_id", "unit_id", "prediction_type", "frame_count", "frames"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "run_id": {"type": "string"},
    "unit_id": {"type": "string"},
    "prediction_type": {"const": "frame_question_answers"},
    "frame_count": {"type": "integer", "minimum": 1},
    "frames": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["idx", "t", "answers"],
        "properties": {
          "idx": {"type": "integer", "minimum": 0},
          "t": {"type": "number", "minimum": 0},
          "answers": {"type": "object", "additionalProperties": {"enum": ["yes", "no", "unclear"]}}
        }
      }
    }
  },
  "additionalProperties": true
}
